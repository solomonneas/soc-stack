# MISP Configuration
# Copy to config.env and edit before deploying.

# MISP admin account
MISP_ADMIN_EMAIL=admin@misp.local
MISP_ADMIN_PASSPHRASE=changeme

# Base URL (use the VM's IP or hostname)
MISP_BASEURL=https://localhost

# MariaDB
MYSQL_PASSWORD=misp-secret
MYSQL_ROOT_PASSWORD=root-secret

# InnoDB buffer pool size
# 4GB VM: 512M (REQUIRED or MariaDB OOMs)
# 8GB VM: 2048M
# 16GB VM: 4096M
INNODB_BUFFER_POOL_SIZE=512M
